# --- ROUTER CONFIGURATION ---
# This description is injected into the LLM Router's prompt to identify the plugin.
DESCRIPTION="Briefly describe the plugin's purpose (e.g., Handles weather forecasts)."

# --- AGENT CORE FEATURES ---
# Special variable: Automatically converted to a list. 
# Used to define the sub-capabilities of this specific plugin's agent.
AGENT_FEATURES="current_weather, forecast_7d, rain_radar"

# --- EXTERNAL LINKS & APIS ---
# Use 'LINK_' for URLs, API endpoints, or file paths.
LINK_API_BASE="https://api.weatherservice.com/v1"
LINK_DOCUMENTATION="https://github.com/youruser/yourproject/wiki"

# --- DATA STRUCTURES ---
# Use 'LIST_' for comma-separated values (converted to a Python list).
LIST_ALLOWED_CITIES="Paris, London, Tokyo"

# Use 'DICO_' for key:value pairs (converted to a Python dictionary).
DICO_HEADERS="Authorization:Bearer_Token, Content-Type:application/json"

# --- PLUGIN SETTINGS ---
# Standard variables
MAX_RETRY=3
TIMEOUT=30

# --- LLM PROMPT REPLACEMENTS ---
# Variables starting with 'REPLACE_' will swap tags in your agents_config.yaml.
REPLACE_WEATHER_UNIT="Celsius"