DESCRIPTION=Calendar, dates, appointments, concerts, schedules
AGENT_MODEL=qwen2.5:3b
AGENT_FEATURES=NONSENSE,NEXT_APPOINTMENT,NEXT_CONCERT,CURRENT_WEEK,NEXT_WEEK,MAIL_NEXT_CONCERT

LINK_CALENDAR=https://calendar.service.com/api/v1/user/token/calendar.ics
USERNAME=Your_Full_Name
DOMAIN=yourdomain.com
USER_MAIL=system@yourdomain.com
PWD_MAIL=your_app_password
IP_MAIL=127.0.0.1
PORT_SMTP_MAIL=1025
PATH_ICS_TEMPLATE=plugins/agenda/template_concert.ics

BLACKLIST_NAMES=SURNAME,GIVEN_NAME,ORG_NAME,CLIENT,BUYER,ORDER,LOCATION,CITY,ID_NUMBER,STATUS

ADDR_KEYWORDS=STREET,BOULEVARD,BLVD,AVENUE,AVE,SQUARE,QUAY,ARENA,STADIUM,HALL,THEATER,CLUB,ROAD,WAY
DICO_MONTHS=jan:01,feb:02,mar:03,apr:04,may:05,jun:06,jul:07,aug:08,sep:09,oct:10,nov:11,dec:12
DICO_VENUES=VENUE_NAME:123 Example Street 75000 City
