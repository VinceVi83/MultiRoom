BEGIN:VCALENDAR
VERSION:2.0
BEGIN:VEVENT
UID:{uid}
DTSTAMP:{now}
SUMMARY:CONCERT: {artist}
DTSTART;TZID=Europe/Paris:{dtstart}
DTEND;TZID=Europe/Paris:{dtend}
LOCATION:{location}
BEGIN:VALARM
TRIGGER:-P1D
ACTION:DISPLAY
DESCRIPTION:Reminder 1 day before
END:VALARM
BEGIN:VALARM
TRIGGER:-PT2H
ACTION:DISPLAY
DESCRIPTION:Reminder 2 hours before
END:VALARM
END:VEVENT
END:VCALENDAR
